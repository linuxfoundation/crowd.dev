#!/usr/bin/env bash
set -e

# Resolve the real path of this script through symlinks so the wrapper works
# when installed to /usr/local/bin or ~/bin.
SRC="${BASH_SOURCE[0]}"
while [ -L "$SRC" ]; do
  DIR="$(cd "$(dirname "$SRC")" && pwd)"
  SRC="$(readlink "$SRC")"
  [[ "$SRC" != /* ]] && SRC="$DIR/$SRC"
done
SCRIPT_DIR="$(cd "$(dirname "$SRC")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
CLI_DIR="$REPO_ROOT/tools/crowd-cli"

if [[ ! -x "$CLI_DIR/node_modules/.bin/tsx" ]]; then
  echo "error: tsx not found. Run: (cd $CLI_DIR && pnpm install)" >&2
  exit 1
fi

exec "$CLI_DIR/node_modules/.bin/tsx" --tsconfig "$CLI_DIR/tsconfig.json" "$CLI_DIR/bin/run.mjs" "$@"

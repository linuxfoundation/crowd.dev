DESCRIPTION >
    - Calculates repository-level forks health score.
    - Returns fork count and benchmark (0-5) per repository.
    - Parameters:
    - `repoUrl`: Optional repository URL for single-repo mode
    - `startDate`: Optional DateTime filter
    - `endDate`: Optional DateTime filter

TAGS "Repository health", "Metrics"

INCLUDE "../includes/health_score_forks.incl" "GROUP_COL=channel" "SOURCE_NODE=repo_health_score_forks_score"

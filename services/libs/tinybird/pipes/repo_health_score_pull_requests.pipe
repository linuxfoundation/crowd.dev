DESCRIPTION >
    - Calculates repository-level pull request activity health score.
    - Returns PR count and benchmark (0-5) per repository for the last 365 days.
    - Parameters:
    - `repoUrl`: Optional repository URL for single-repo mode
    - `startDate`: Optional DateTime filter
    - `endDate`: Optional DateTime filter

TAGS "Repository health", "Metrics"

INCLUDE "../includes/health_score_pull_requests.incl" "GROUP_COL=channel" "SOURCE_NODE=repo_health_score_pull_requests_score"
